APP_NAME=CarWash DG API
DEBUG=true
API_PREFIX=/api
# Con o sin barra final (ambas formas se aceptan)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://admin.carwashdg.com,https://carwashdg.com
# Usuario MySQL debe usar caching_sha2_password (no mysql_native_password en MySQL 8.4+)
DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/carwashdg
JWT_SECRET_KEY=change-me-in-production-use-env
JWT_EXPIRE_MINUTES=10080
DEFAULT_ADMIN_EMAIL=admin@carwashdg.com
DEFAULT_ADMIN_PASSWORD=123456789
